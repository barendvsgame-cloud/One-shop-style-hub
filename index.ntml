<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>One Shop Style Hub</title>
    <link rel="stylesheet" href="styles.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <div class="app-container">
        <!-- Status Bar -->
        <div class="status-bar">
            <div class="time">07:48</div>
            <div class="status-icons">
                <span class="speed">8.00 KB/S</span>
                <i class="fas fa-wifi"></i>
                <i class="fas fa-signal"></i>
                <i class="fas fa-battery-three-quarters"></i>
                <span class="battery">69%</span>
            </div>
        </div>

        <!-- Header -->
        <header class="header">
            <button class="back-btn"><i class="fas fa-chevron-left"></i></button>
            <h1>One Shop Style Hub</h1>
            <button class="share-btn"><i class="fas fa-share-square"></i></button>
        </header>

        <!-- Top Banner -->
        <div class="top-banner">
            <i class="fas fa-fire"></i>
            <span>Fashion + Tech Deals Updated Daily</span>
        </div>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Action Bar -->
            <div class="action-bar">
                <div class="logo-icon">
                    <i class="fas fa-fire"></i>
                </div>
                <div class="action-buttons">
                    <button class="location-btn">
                        <i class="fas fa-map-marker-alt"></i>
                        <i class="fas fa-chevron-down"></i>
                    </button>
                    <button class="calendar-btn"><i class="far fa-calendar"></i></button>
                    <button class="menu-btn"><i class="fas fa-bars"></i></button>
                </div>
            </div>

            <!-- Live Status -->
            <div class="live-status">
                <span class="live-badge"><span class="pulse"></span> LIVE NOW</span>
                <span class="updated"><i class="far fa-clock"></i> Updated 8 min ago</span>
            </div>

            <!-- Hero Section -->
            <div class="hero">
                <h2 class="hero-title">
                    Style Your <span class="highlight">Tech.</span><br>
                    Tech Your <span class="highlight">Style.</span>
                </h2>
                <p class="hero-description">
                    South Africa's first fashion + tech deal hub. Earn up to <span class="commission">10% commission</span> on style, tech, sneakers, and gadgets from Zando, Mr Price, and premium retailers.
                </p>
            </div>

            <!-- CTA Buttons -->
            <div class="cta-buttons">
                <button class="btn-primary">
                    Shop Deals Now <i class="fas fa-arrow-right"></i>
                </button>
                <button class="btn-secondary">
                    View Retailers
                </button>
            </div>

            <!-- Stats -->
            <div class="stats">
                <div class="stat-item">
                    <div class="stat-icon"><i class="fas fa-shopping-bag"></i></div>
                    <div class="stat-info">
                        <span class="stat-number">50+</span>
                        <span class="stat-label">Daily Deals</span>
                    </div>
                </div>
                <div class="stat-item">
                    <div class="stat-icon"><i class="fas fa-chart-line"></i></div>
                    <div class="stat-info">
                        <span class="stat-number">10%</span>
                        <span class="stat-label">Max Commission</span>
                    </div>
                </div>
                <div class="stat-item">
                    <div class="stat-icon"><i class="fas fa-bolt"></i></div>
                    <div class="stat-info">
                        <span class="stat-number">4</span>
                        <span class="stat-label">Top Retailers</span>
                    </div>
                </div>
            </div>
        </main>

        <!-- Floating Action Button -->
        <div class="fab">
            <i class="fas fa-robot"></i>
            <span>Kimi Agent</span>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
